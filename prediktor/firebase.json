{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [{ "source": "**", "destination": "/index.html" }]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "secretEnvironmentVariables": [
      { "key": "ANTHROPIC_API_KEY" },
      { "key": "ODDS_API_KEY" }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
